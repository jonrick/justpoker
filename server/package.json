{
    "name": "jp-server",
    "version": "0.2.0",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "prebuild": "node -e \"require('fs').rmSync('dist', {recursive:true, force:true})\" && npm run lint",
        "lint": "eslint --quiet --fix --config .eslintrc.js --no-eslintrc ./src/**/*.ts ../ui/src/shared/**/**/*",
        "build": "tsc",
        "prestart": "npm run build",
        "start": "node ./dist/server/server/src/server/server.js",
        "debug": "npm run build && node inspect ./dist/server/server/src/server/server.js",
        "start-d": "npm run build && LOG_LEVEL=debug node ./dist/server/server/src/server/server.js",
        "test": "echo \"Error: no test specified\" && exit 1"
    },
    "devDependencies": {
        "@types/body-parser": "^1.19.0",
        "@types/color": "^3.0.1",
        "@types/cookie": "^0.3.3",
        "@types/express": "^4.17.3",
        "@types/lodash": "^4.14.155",
        "@types/node": "^20.12.7",
        "@types/query-string": "^6.3.0",
        "@types/winston": "^2.4.4",
        "@types/ws": "^7.2.3",
        "@typescript-eslint/eslint-plugin": "^5.62.0",
        "@typescript-eslint/parser": "^5.62.0",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^8.10.0",
        "eslint-plugin-prettier": "^5.1.3",
        "prettier": "^3.2.5",
        "typescript": "^5.4.5"
    },
    "dependencies": {
        "@sendgrid/mail": "^7.2.1",
        "axios": "^1.7.9",
        "body-parser": "^1.19.0",
        "express": "^4.17.1",
        "human-readable-ids": "^1.0.4",
        "lodash": "^4.17.23",
        "pokersolver": "^2.1.3",
        "reflect-metadata": "^0.1.13",
        "typedi": "^0.8.0",
        "winston": "^3.2.1",
        "ws": "^7.2.3"
    }
}
